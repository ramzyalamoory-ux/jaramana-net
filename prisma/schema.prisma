// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// جدول المشتركين
model Subscriber {
  id            Int        @id @default(autoincrement())
  name          String
  phone         String     @unique
  address       String?
  monthlyFee    Float      @default(0)
  isActive      Boolean    @default(true)
  notes         String?
  // PPPoE & Network
  pppoeUser        String?    @unique
  pppoePassword    String?
  ipAddress        String?
  isOnline         Boolean    @default(false)
  lastSeen         DateTime?
  macAddress       String?
  mikrotikDeviceId Int?
  // Grace Period & Service Control
  graceDays     Int        @default(0)
  serviceStatus String     @default("active")
  suspendedAt   DateTime?
  // Subscription
  expiryDate    DateTime?
  lastRenewedAt DateTime?
  // Relations
  invoices      Invoice[]
  tickets       Ticket[]
  connections   ConnectionLog[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@index([isOnline])
  @@index([pppoeUser])
  @@index([serviceStatus])
  @@index([mikrotikDeviceId])
}

// جدول الفواتير
model Invoice {
  id            Int        @id @default(autoincrement())
  subscriberId  Int
  subscriber    Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  month         String
  amount        Float
  isPaid        Boolean    @default(false)
  dueDate       DateTime
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@unique([subscriberId, month])
  @@index([isPaid])
  @@index([month])
}

// جدول أنواع المنتجات
model ProductCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  nameEn      String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// جدول المنتجات
model Product {
  id           Int                   @id @default(autoincrement())
  name         String
  categoryId   Int
  category     ProductCategory       @relation(fields: [categoryId], references: [id])
  unit         String                @default("قطعة")
  currentStock Int                   @default(0)
  minStock     Int                   @default(5)
  price        Float                 @default(0)
  notes        String?
  transactions InventoryTransaction[]
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([categoryId])
  @@index([name])
}

// جدول حركة المخزون
model InventoryTransaction {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  type        String
  quantity    Int
  reason      String?
  recipient   String?
  supplier    String?
  price       Float?
  notes       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([date])
}

// جدول الإعدادات
model Setting {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  value     String
  updatedAt DateTime @updatedAt
}

// جدول تذاكر الدعم
model Ticket {
  id           Int        @id @default(autoincrement())
  subscriberId Int?
  subscriber   Subscriber? @relation(fields: [subscriberId], references: [id], onDelete: SetNull)
  name         String
  phone        String
  subject      String
  message      String
  status       String    @default("open")
  priority     String    @default("normal")
  response     String?
  respondedAt  DateTime?
  respondedBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// جدول سجل النشاطات
model ActivityLog {
  id        Int      @id @default(autoincrement())
  action    String
  details   String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

// جدول الإشعارات
model Notification {
  id          Int      @id @default(autoincrement())
  type        String
  title       String
  message     String
  isRead      Boolean  @default(false)
  relatedId   Int?
  createdAt   DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// جدول النسخ الاحتياطي
model Backup {
  id          Int      @id @default(autoincrement())
  filename    String
  size        Int
  type        String
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// جدول أجهزة MikroTik
model MikroTikDevice {
  id          Int      @id @default(autoincrement())
  name        String
  host        String
  port        Int      @default(8728)
  username    String
  password    String
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([host])
}

// جدول سجل الاتصالات
model ConnectionLog {
  id             Int        @id @default(autoincrement())
  subscriberId   Int
  subscriber     Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  ipAddress      String?
  macAddress     String?
  action         String
  duration       Int?
  bytesIn        Int?
  bytesOut       Int?
  createdAt      DateTime   @default(now())

  @@index([subscriberId])
  @@index([action])
  @@index([createdAt])
}

// جدول سجل محاولات الدخول
model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  username  String
  success   Boolean
  reason    String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([ip])
  @@index([createdAt])
  @@index([success])
}

// جدول جلسات المسؤول
model AdminSession {
  id           Int      @id @default(autoincrement())
  token        String   @unique
  ip           String
  userAgent    String?
  lastActivity DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([expiresAt])
  @@index([ip])
}

// جدول قوالب الرسائل
model MessageTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  category    String
  subject     String?
  message     String
  variables   String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([isActive])
}
